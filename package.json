{
  "name": "aldas-ci",
  "private": true,
  "version": "1.0.0",
  "description": "Site professionnel de gestion multi-services en Côte d'Ivoire : Location de voitures, Navettes, Conciergerie, Événementiel",
  "author": "ÁLDÁS CI",
  "license": "UNLICENSED",
  "type": "module",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "npm run seo:sitemap && vite build",
    "preview": "vite preview",
    "lint": "eslint src --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint src --ext ts,tsx --fix",
    "lint:strict": "npm run lint -- --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "typecheck:watch": "tsc --noEmit --watch",
    "test": "echo \"No tests specified\" && exit 0",
    "test:watch": "npm run test -- --watch",
    "analyze": "npm run build -- --mode analyze",
    "analyze:bundle": "npx vite-bundle-visualizer",
    "seo:sitemap": "node scripts/generate-sitemap.js",
    "seo:validate": "node scripts/validate-seo.js",
    "seo:indexable": "node scripts/check-indexability.js",
    "seo:all": "npm run seo:sitemap && npm run seo:validate && npm run seo:indexable",
    "prebuild": "npm run lint:strict && npm run typecheck",
    "postbuild": "npm run seo:sitemap && echo \"✅ Build terminé + sitemap généré\"",
    "predeploy": "npm run build && npm run seo:validate",
    "deploy": "echo \"🚀 Déploiement en cours...\" && npm run preview",
    "clean": "rm -rf dist node_modules/.vite public/sitemap.xml",
    "clean:all": "npm run clean && rm -rf node_modules package-lock.json",
    "prepare": "husky install",
    "prepare:husky": "npx husky-init && npm install"
  },
  "dependencies": {
    "framer-motion": "^12.38.0",
    "lucide-react": "^0.577.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-helmet-async": "^3.0.0",
    "react-router-dom": "^7.13.1",
    "swiper": "^12.1.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.15.21",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.0",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "husky": "^8.0.0",
    "install": "^0.13.0",
    "jsdom": "^24.1.3",
    "lint-staged": "^16.1.2",
    "postcss": "^8.5.8",
    "postcss-nested": "^7.0.2",
    "tailwindcss": "^3.4.1",
    "terser": "^5.44.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^8.0.0",
    "vite-imagetools": "^10.0.0",
    "vite-plugin-checker": "^0.9.3"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead",
    "not ie 11"
  ],
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "eslint --fix",
      "git add"
    ],
    "src/**/*.{css,scss}": [
      "stylelint --fix",
      "git add"
    ]
  },
  "volta": {
    "node": "20.11.0",
    "npm": "10.2.4"
  }
}
